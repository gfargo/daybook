{
  "name": "@daybook/ledger",
  "version": "0.0.0",
  "private": true,
  "description": "Normalized RawEvent + LedgerEntry types and SQLite storage",
  "license": "MIT",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./types": {
      "types": "./dist/types.d.ts",
      "import": "./dist/types.js"
    },
    "./db": {
      "types": "./dist/db.d.ts",
      "import": "./dist/db.js"
    },
    "./repo": {
      "types": "./dist/repo.d.ts",
      "import": "./dist/repo.js"
    }
  },
  "scripts": {
    "build": "tsup src/index.ts src/types.ts src/db.ts src/repo.ts --format esm --dts --clean",
    "test": "vitest run"
  },
  "dependencies": {
    "better-sqlite3": "^11.0.0",
    "decimal.js": "^10.4.3"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.0"
  }
}
