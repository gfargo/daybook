{
  "name": "@gfargo/daybook",
  "version": "0.2.0",
  "private": false,
  "description": "Self-hosted crypto wallet auditing and tax reporting",
  "license": "MIT",
  "author": "Griffen Fargo",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/gfargo/daybook.git",
    "directory": "packages/cli"
  },
  "keywords": [
    "crypto",
    "tax",
    "cost-basis",
    "ledger",
    "cli",
    "ethereum",
    "coinbase",
    "kraken"
  ],
  "type": "module",
  "bin": {
    "daybook": "dist/index.js"
  },
  "publishConfig": {
    "access": "public"
  },
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "scripts": {
    "build": "tsup src/index.ts --format esm --dts --tsconfig tsconfig.build.json --clean && mkdir -p dist/migrations dist/templates && cp ../ledger/src/migrations/*.sql dist/migrations/ && cp ../tax/src/templates/*.pdf dist/templates/",
    "start": "node dist/index.js",
    "test": "vitest run"
  },
  "dependencies": {
    "alchemy-sdk": "^3.5.0",
    "better-sqlite3": "^11.0.0",
    "chalk": "5",
    "commander": "^12.0.0",
    "csv-parse": "^5.5.0",
    "csv-stringify": "^6.5.0",
    "decimal.js": "^10.4.3",
    "ink": "^7.0.1",
    "pdf-lib": "^1.17.1",
    "pino": "^9.0.0",
    "react": "^19.2.5",
    "viem": "^2.21.0",
    "zod": "^3.23.0"
  },
  "devDependencies": {
    "@daybook/classifier": "workspace:*",
    "@daybook/ledger": "workspace:*",
    "@daybook/sources": "workspace:*",
    "@daybook/tax": "workspace:*",
    "@types/react": "^19.2.14"
  }
}
