{
  "name": "@daybook/sources",
  "version": "0.0.0",
  "private": true,
  "description": "Adapters that turn raw source data into normalized RawEvents",
  "license": "MIT",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./binance": {
      "types": "./dist/binance/index.d.ts",
      "import": "./dist/binance/index.js"
    },
    "./bitget": {
      "types": "./dist/bitget/index.d.ts",
      "import": "./dist/bitget/index.js"
    },
    "./bybit": {
      "types": "./dist/bybit/index.d.ts",
      "import": "./dist/bybit/index.js"
    },
    "./coinbase": {
      "types": "./dist/coinbase/index.d.ts",
      "import": "./dist/coinbase/index.js"
    },
    "./crypto-com": {
      "types": "./dist/crypto-com/index.d.ts",
      "import": "./dist/crypto-com/index.js"
    },
    "./evm": {
      "types": "./dist/evm/index.d.ts",
      "import": "./dist/evm/index.js"
    },
    "./gateio": {
      "types": "./dist/gateio/index.d.ts",
      "import": "./dist/gateio/index.js"
    },
    "./generic-csv": {
      "types": "./dist/generic-csv/index.d.ts",
      "import": "./dist/generic-csv/index.js"
    },
    "./gemini": {
      "types": "./dist/gemini/index.d.ts",
      "import": "./dist/gemini/index.js"
    },
    "./kraken": {
      "types": "./dist/kraken/index.d.ts",
      "import": "./dist/kraken/index.js"
    },
    "./mexc": {
      "types": "./dist/mexc/index.d.ts",
      "import": "./dist/mexc/index.js"
    },
    "./okx": {
      "types": "./dist/okx/index.d.ts",
      "import": "./dist/okx/index.js"
    },
    "./robinhood": {
      "types": "./dist/robinhood/index.d.ts",
      "import": "./dist/robinhood/index.js"
    }
  },
  "scripts": {
    "build": "tsup src/index.ts src/binance/index.ts src/bitget/index.ts src/bybit/index.ts src/coinbase/index.ts src/crypto-com/index.ts src/evm/index.ts src/gateio/index.ts src/gemini/index.ts src/generic-csv/index.ts src/kraken/index.ts src/mexc/index.ts src/okx/index.ts src/robinhood/index.ts --format esm --dts --tsconfig tsconfig.build.json --clean",
    "test": "vitest run"
  },
  "dependencies": {
    "@daybook/ledger": "workspace:*",
    "alchemy-sdk": "^3.5.0",
    "csv-parse": "^5.5.0",
    "decimal.js": "^10.4.3",
    "viem": "^2.21.0",
    "zod": "^3.23.0"
  },
  "devDependencies": {
    "fast-check": "^4.7.0"
  }
}
