{
  "name": "daybook",
  "version": "0.1.0",
  "private": false,
  "description": "Self-hosted crypto wallet auditing and tax reporting",
  "license": "MIT",
  "author": "Griffen Fargo",
  "repository": {
    "type": "git",
    "url": "https://github.com/gfargo/daybook.git",
    "directory": "packages/cli"
  },
  "keywords": [
    "crypto",
    "tax",
    "cost-basis",
    "ledger",
    "cli",
    "ethereum",
    "coinbase",
    "kraken"
  ],
  "type": "module",
  "bin": {
    "daybook": "./dist/index.js"
  },
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "scripts": {
    "build": "tsup src/index.ts --format esm --dts --tsconfig tsconfig.build.json --clean",
    "start": "node dist/index.js",
    "test": "vitest run"
  },
  "dependencies": {
    "@daybook/classifier": "workspace:*",
    "@daybook/ledger": "workspace:*",
    "@daybook/sources": "workspace:*",
    "@daybook/tax": "workspace:*",
    "chalk": "5",
    "commander": "^12.0.0",
    "decimal.js": "^10.4.3",
    "ink": "^7.0.1",
    "pino": "^9.0.0",
    "react": "^19.2.5",
    "zod": "^3.23.0"
  },
  "devDependencies": {
    "@types/react": "^19.2.14"
  }
}
