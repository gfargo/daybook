{
  "name": "daybook",
  "version": "0.4.0",
  "private": true,
  "description": "Self-hosted crypto wallet auditing and tax reporting",
  "license": "MIT",
  "author": "Griffen Fargo",
  "type": "module",
  "engines": {
    "node": ">=20"
  },
  "packageManager": "pnpm@9.0.0",
  "workspaces": [
    "packages/*"
  ],
  "scripts": {
    "build": "pnpm -r build",
    "test": "vitest run",
    "coverage": "vitest run --coverage",
    "test:watch": "vitest",
    "lint": "eslint packages",
    "typecheck": "tsc -b",
    "clean": "pnpm -r exec rm -rf dist",
    "release": "release-it",
    "release:dry": "release-it --dry-run"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.4",
    "@types/node": "^22.0.0",
    "@vitest/coverage-v8": "^2.0.0",
    "eslint": "^9.0.0",
    "release-it": "18",
    "tsup": "^8.0.0",
    "typescript": "^5.5.0",
    "typescript-eslint": "^8.59.2",
    "vitest": "^2.0.0"
  }
}
