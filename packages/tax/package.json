{
  "name": "@daybook/tax",
  "version": "0.0.0",
  "private": true,
  "description": "Cost-basis lot tracking, gain/loss computation, tax-ready CSV export",
  "license": "MIT",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "scripts": {
    "copy-templates": "mkdir -p dist/templates && cp src/templates/*.pdf dist/templates/",
    "build": "tsup src/index.ts --format esm --dts --tsconfig tsconfig.build.json --clean --onSuccess 'pnpm copy-templates'",
    "test": "vitest run"
  },
  "dependencies": {
    "@daybook/ledger": "workspace:*",
    "csv-parse": "^5.5.0",
    "csv-stringify": "^6.5.0",
    "decimal.js": "^10.4.3",
    "pdf-lib": "^1.17.1"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.0",
    "better-sqlite3": "^11.0.0",
    "fast-check": "^4.7.0"
  }
}
